{
  "outputDirectory": "public",
  "framework": null,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "ggene-eternal-unit-db.vercel.app"
        }
      ],
      "destination": "https://gget-db.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "mh-dev-gget-db.vercel.app"
        }
      ],
      "destination": "https://gget-db.com/$1",
      "permanent": true
    }
  ]
}